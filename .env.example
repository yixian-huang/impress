# Docker Compose Environment Variables
# Copy this file to .env and update values as needed

# Database Configuration (for docker-compose.yml PostgreSQL mode)
POSTGRES_DB=inkless
POSTGRES_USER=inkless
POSTGRES_PASSWORD=inkless_dev_password

# Backend API Configuration
PORT=8088
# Default to SQLite for local standalone runs:
# DB_DSN=file:./data/inkless.db?cache=shared&mode=rwc
# For docker-compose.yml PostgreSQL mode:
DB_DSN=host=db user=inkless password=inkless_dev_password dbname=inkless port=5432 sslmode=disable TimeZone=Asia/Shanghai
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
ENV=development
BACKUP_DIR=./backups
PLUGIN_DIR=./plugins
PLUGIN_DATA_DIR=./data/plugins
# External plugin packages execute as trusted server-side code.
ENABLE_EXTERNAL_PLUGINS=false

# Canonical production origin (uncomment for the operated inkless.run instance)
# BASE_URL=https://inkless.run
# CORS_ALLOWED_ORIGINS=https://inkless.run

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8088
