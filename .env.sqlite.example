# Lightweight backend runtime using SQLite
PORT=8088
DB_DSN=file:./data/inkless.db?cache=shared&mode=rwc
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
ENV=development
UPLOAD_DIR=./uploads
PLUGIN_DIR=./plugins
PLUGIN_DATA_DIR=./data/plugins
# External plugin packages execute as trusted server-side code.
ENABLE_EXTERNAL_PLUGINS=false

# Canonical production origin (uncomment for the operated inkless.run instance)
# BASE_URL=https://inkless.run
# CORS_ALLOWED_ORIGINS=https://inkless.run
